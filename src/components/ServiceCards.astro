---
interface ServiceCard {
  image: string;
  title: string;
  bookingHref?: string;
  detailsHref?: string;
  bookingLabel?: string;
  detailsLabel?: string;
}

interface Props {
  services?: ServiceCard[];
  sectionTitle?: string;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function addBase(href: string) {
  if (href.startsWith('#') || href.startsWith('http')) {
    return href;
  }
  return `${base}/${href.replace(/^\//, '')}`;
}

const defaultServices: ServiceCard[] = [
  {
    image: '/images/services/chip-removal.jpg',
    title: 'chip removal',
    bookingHref: '#booking',
    detailsHref: '#chip-removal',
  },
  {
    image: '/images/services/ppf.jpg',
    title: 'PPF',
    bookingHref: '#booking',
    detailsHref: '#ppf',
  },
  {
    image: '/images/services/water-stone.jpg',
    title: 'water stone removal',
    bookingHref: '#booking',
    detailsHref: '#water-stone',
  },
  {
    image: '/images/services/headlights.jpg',
    title: 'headlights',
    bookingHref: '#booking',
    detailsHref: '#headlights',
  },
];

const { 
  services = defaultServices,
  sectionTitle 
} = Astro.props;
---

<section class="services-section">
  {sectionTitle && <h2 class="section-title">{sectionTitle}</h2>}
  
  <div class="services-container">
    <div class="services-track">
      {services.map((service, index) => (
        <article class="service-card" data-index={index}>
          <div 
            class="card-image" 
            style={`background-image: url(${service.image})`}
          >
            <div class="card-overlay"></div>
          </div>
          
<div class="card-content">
            <h3 class="card-title">{service.title}</h3>
            <div class="card-buttons">
              <a 
                href={addBase(service.bookingHref || '#booking')} 
                class="btn btn-primary"
              >
                {service.bookingLabel || 'booking'}
              </a>
              <a 
                href={addBase(service.detailsHref || '#')} 
                class="btn btn-secondary"
              >
                {service.detailsLabel || 'details'}
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
  
  <div class="services-dots">
    {services.map((_, index) => (
      <button 
        class={`dot ${index === 0 ? 'active' : ''}`}
        data-slide={index}
        aria-label={`Перейти к услуге ${index + 1}`}
      />
    ))}
  </div>
</section>

<style>
  .services-section {
    padding: 3rem 0;
    background: var(--color-bg);
  }

  .section-title {
    font-family: var(--font-main);
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 600;
    color: var(--color-text);
    text-align: center;
    margin: 0 0 2rem;
    padding: 0 1.5rem;
  }

  .services-container {
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .services-container::-webkit-scrollbar {
    display: none;
  }

  .services-track {
    display: flex;
    gap: 1rem;
    padding: 0 1.5rem;
    width: max-content;
  }

  .service-card {
    position: relative;
    flex-shrink: 0;
    width: 80vw;
    aspect-ratio: 7 / 5;
    border-radius: 12px;
    overflow: hidden;
    scroll-snap-align: center;
    transition: transform 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
  }

  .card-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: #2a2a2a;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.3) 50%,
      rgba(0, 0, 0, 0.7) 100%
    );
  }

  .card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    z-index: 10;
  }

  .card-title {
    font-family: var(--font-main);
    font-size: 1.375rem;
    font-weight: 600;
    color: #fff;
    margin: 0 0 1rem;
    line-height: 1.3;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
  }

  .card-buttons {
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

 

  .services-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.2);
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .dot:hover {
    background: rgba(0, 0, 0, 0.4);
  }

  .dot.active {
    background: var(--color-accent);
    transform: scale(1.25);
  }

  /* Tablet */
  @media (min-width: 600px) {
    .services-track {
      padding: 0 2rem;
      gap: 1.25rem;
    }

    .service-card {
      width: 60vw;
    }

    .card-title {
      font-size: 1.5rem;
    }
  }

  /* Desktop - still horizontal scroll */
  @media (min-width: 1024px) {
    .services-track {
      padding: 0 3rem;
      gap: 1.5rem;
    }

    .service-card {
      width: 40vw;
    }
  }

  /* Large desktop */
  @media (min-width: 1400px) {
    .services-track {
      gap: 2rem;
    }

    .service-card {
      width: 35vw;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sections = document.querySelectorAll('.services-section');
    
    sections.forEach((section) => {
      const container = section.querySelector('.services-container') as HTMLElement;
      const cards = section.querySelectorAll('.service-card');
      const dots = section.querySelectorAll('.services-dots .dot');
      let currentIndex = 0;

      if (!container || cards.length === 0) return;

      // Dot click
      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          const card = cards[index] as HTMLElement;
          const containerRect = container.getBoundingClientRect();
          const cardRect = card.getBoundingClientRect();
          const scrollLeft = card.offsetLeft - (containerRect.width / 2) + (cardRect.width / 2);
          
          container.scrollTo({ left: scrollLeft, behavior: 'smooth' });
          currentIndex = index;
          updateDots();
        });
      });

      // Update on scroll
      container.addEventListener('scroll', () => {
        const containerRect = container.getBoundingClientRect();
        const containerCenter = containerRect.left + containerRect.width / 2;
        let closestIndex = 0;
        let closestDistance = Infinity;

        cards.forEach((card, index) => {
          const cardRect = card.getBoundingClientRect();
          const cardCenter = cardRect.left + cardRect.width / 2;
          const distance = Math.abs(containerCenter - cardCenter);
          if (distance < closestDistance) {
            closestDistance = distance;
            closestIndex = index;
          }
        });

        if (closestIndex !== currentIndex) {
          currentIndex = closestIndex;
          updateDots();
        }
      });

      function updateDots() {
        dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === currentIndex);
        });
      }
    });
  });
</script>