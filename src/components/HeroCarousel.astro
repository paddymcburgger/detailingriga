---
interface Slide {
  type: 'image' | 'video';
  src: string;
  poster?: string;
  title: string;
  subtitle: string;
  primaryBtn: {
    label: string;
    href: string;
  };
  secondaryBtn: {
    label: string;
    href: string;
  };
}

interface Props {
  slides?: Slide[];
}

const defaultSlides: Slide[] = [
  {
    type: 'image',
    src: '/images/hero-1.jpg',
    title: 'Полировка стёкол',
    subtitle: '-30% вместе с антидождь',
    primaryBtn: { label: 'резервация', href: '#booking' },
    secondaryBtn: { label: 'об услуге', href: '#service' },
  },
  {
    type: 'image',
    src: '/images/hero-2.jpg',
    title: 'Керамическое покрытие',
    subtitle: 'Защита до 5 лет',
    primaryBtn: { label: 'резервация', href: '#booking' },
    secondaryBtn: { label: 'об услуге', href: '#service' },
  },
];

const { slides = defaultSlides } = Astro.props;
---

<section class="hero">
  <div class="carousel">
    <div class="carousel-track">
      {slides.map((slide, index) => (
        <div class={`slide ${index === 0 ? 'active' : ''}`} data-index={index}>
          {slide.type === 'video' ? (
            <video
              class="slide-media"
              src={slide.src}
              poster={slide.poster}
              autoplay
              muted
              loop
              playsinline
            />
          ) : (
            <div 
              class="slide-media slide-image" 
              style={`background-image: url(${slide.src})`}
            />
          )}
          
          <div class="slide-overlay"></div>
          
          <div class="slide-content">
            <h1 class="slide-title">{slide.title}</h1>
            <p class="slide-subtitle">{slide.subtitle}</p>
            <div class="slide-buttons">
              <a href={slide.primaryBtn.href} class="btn btn-primary">
                {slide.primaryBtn.label}
              </a>
              <a href={slide.secondaryBtn.href} class="btn btn-secondary">
                {slide.secondaryBtn.label}
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    {slides.length > 1 && (
      <div class="carousel-dots">
        {slides.map((_, index) => (
          <button 
            class={`dot ${index === 0 ? 'active' : ''}`}
            data-slide={index}
            aria-label={`Перейти к слайду ${index + 1}`}
          />
        ))}
      </div>
    )}
    
    {slides.length > 1 && (
      <>
        <button class="carousel-arrow carousel-prev" aria-label="Предыдущий слайд">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-6-6 6-6" />
          </svg>
        </button>
        <button class="carousel-arrow carousel-next" aria-label="Следующий слайд">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 18l6-6-6-6" />
          </svg>
        </button>
      </>
    )}
  </div>
</section>

<style>
  .hero {
    margin-top: 57px;
    position: relative;
    overflow: hidden;
  }

.carousel {
  position: relative;
  width: 100%;
  height: calc(100vh - 57px);
  min-height: 500px;
  max-height: 75vh;
}

  .carousel-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.8s ease, visibility 0.8s ease;
  }

  .slide.active {
    opacity: 1;
    visibility: visible;
  }

  .slide-media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .slide-image {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: #1a1a1a;
    background-image: 
      linear-gradient(135deg, rgba(139, 0, 0, 0.3) 0%, transparent 50%),
      linear-gradient(225deg, rgba(80, 0, 0, 0.4) 0%, transparent 50%),
      linear-gradient(180deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.6) 100%);
  }

  .slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.1) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  .slide-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
    z-index: 10;
  }

  .slide-title {
    font-family: var(--font-main);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s ease 0.2s forwards;
  }

  .slide.active .slide-title {
    animation: fadeInUp 0.8s ease 0.2s forwards;
  }

  .slide-subtitle {
    font-family: var(--font-main);
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 2rem;
    letter-spacing: 0.02em;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.5);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s ease 0.35s forwards;
  }

  .slide.active .slide-subtitle {
    animation: fadeInUp 0.8s ease 0.35s forwards;
  }

  .slide-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s ease 0.5s forwards;
  }

  .slide.active .slide-buttons {
    animation: fadeInUp 0.8s ease 0.5s forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }



  .carousel-dots {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.75rem;
    z-index: 20;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .dot:hover {
    background: rgba(255, 255, 255, 0.7);
  }

  .dot.active {
    background: var(--color-white);
    transform: scale(1.2);
  }

  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(10px);
    color: #fff;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 20;
    transition: all 0.3s ease;
  }

  .carousel-arrow:hover {
    background: rgba(0, 0, 0, 0.5);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .carousel-prev {
    left: 1.5rem;
  }

  .carousel-next {
    right: 1.5rem;
  }

  @media (min-width: 768px) {
    .hero {
      margin-top: 65px;
      max-height: 75vh;
    }

    .carousel {
      height: calc(100vh - 65px);
    }

    .carousel-arrow {
      display: flex;
    }

    .slide-buttons {
      gap: 1.25rem;
    }

    .btn {
      padding: 1rem 2rem;
    }
  }

  @media (min-width: 1024px) {
    .carousel-prev {
      left: 3rem;
    }

    .carousel-next {
      right: 3rem;
    }
  }
</style>

<script>
  class Carousel {
    private slides: NodeListOf<Element>;
    private dots: NodeListOf<Element>;
    private prevBtn: HTMLElement | null;
    private nextBtn: HTMLElement | null;
    private currentIndex: number = 0;
    private autoplayInterval: number | null = null;
    private autoplayDelay: number = 6000;

    constructor() {
      this.slides = document.querySelectorAll('.slide');
      this.dots = document.querySelectorAll('.dot');
      this.prevBtn = document.querySelector('.carousel-prev');
      this.nextBtn = document.querySelector('.carousel-next');

      if (this.slides.length > 1) {
        this.init();
      }
    }

    init() {
      this.dots.forEach((dot, index) => {
        dot.addEventListener('click', () => this.goToSlide(index));
      });

      this.prevBtn?.addEventListener('click', () => this.prevSlide());
      this.nextBtn?.addEventListener('click', () => this.nextSlide());

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') this.prevSlide();
        if (e.key === 'ArrowRight') this.nextSlide();
      });

      let touchStartX = 0;
      let touchEndX = 0;
      const carousel = document.querySelector('.carousel');

      carousel?.addEventListener('touchstart', (e: Event) => {
        touchStartX = (e as TouchEvent).changedTouches[0].screenX;
      });

      carousel?.addEventListener('touchend', (e: Event) => {
        touchEndX = (e as TouchEvent).changedTouches[0].screenX;
        this.handleSwipe(touchStartX, touchEndX);
      });

      this.startAutoplay();

      carousel?.addEventListener('mouseenter', () => this.stopAutoplay());
      carousel?.addEventListener('mouseleave', () => this.startAutoplay());
    }

    goToSlide(index: number) {
      this.slides[this.currentIndex]?.classList.remove('active');
      this.dots[this.currentIndex]?.classList.remove('active');

      this.currentIndex = index;

      this.slides[this.currentIndex]?.classList.add('active');
      this.dots[this.currentIndex]?.classList.add('active');

      this.resetAutoplay();
    }

    nextSlide() {
      const next = (this.currentIndex + 1) % this.slides.length;
      this.goToSlide(next);
    }

    prevSlide() {
      const prev = (this.currentIndex - 1 + this.slides.length) % this.slides.length;
      this.goToSlide(prev);
    }

    handleSwipe(startX: number, endX: number) {
      const threshold = 50;
      const diff = startX - endX;

      if (Math.abs(diff) > threshold) {
        if (diff > 0) {
          this.nextSlide();
        } else {
          this.prevSlide();
        }
      }
    }

    startAutoplay() {
      this.autoplayInterval = window.setInterval(() => {
        this.nextSlide();
      }, this.autoplayDelay);
    }

    stopAutoplay() {
      if (this.autoplayInterval) {
        clearInterval(this.autoplayInterval);
        this.autoplayInterval = null;
      }
    }

    resetAutoplay() {
      this.stopAutoplay();
      this.startAutoplay();
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    new Carousel();
  });
</script>
