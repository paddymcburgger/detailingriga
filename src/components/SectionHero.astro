---
interface Props {
  title: string;
  subtitle: string;
  backgroundImage: ImageMetadata;
  primaryBtn?: { label: string; href: string };
  secondaryBtn?: { label: string; href: string };
}

const { title, subtitle, backgroundImage, primaryBtn, secondaryBtn } = Astro.props;
---

<section class="hero">
  <div class="hero-slide">
    <div 
      class="slide-media slide-image" 
      style={`background-image: url(${backgroundImage.src})`}
    ></div>
    
    <div class="slide-overlay"></div>
    
    <div class="slide-content">
      <h1 class="slide-title">{title}</h1>
      <p class="slide-subtitle">{subtitle}</p>
      {(primaryBtn || secondaryBtn) && (
        <div class="slide-buttons">
          {primaryBtn && (
            <a href={primaryBtn.href} class="btn btn-primary">
              {primaryBtn.label}
            </a>
          )}
          {secondaryBtn && (
            <a href={secondaryBtn.href} class="btn btn-secondary">
              {secondaryBtn.label}
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    margin-top: 57px;
    position: relative;
    overflow: hidden;
    width: 100%;
    height: calc(100vh - 57px);
    min-height: 500px;
    max-height: 900px;
  }

  .hero-slide {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .slide-media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .slide-image {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: #1a1a1a;
  }

  .slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.1) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  .slide-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
    z-index: 10;
  }

  .slide-title {
    font-family: var(--font-main);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
  }

.slide-subtitle {
  font-family: var(--font-main);
  font-size: clamp(1rem, 2.5vw, 1.25rem);
  font-weight: 400;
  color: rgba(255, 255, 255, 0.9);
  margin: 0 0 2rem;
  letter-spacing: 0.02em;
  text-shadow: 0 1px 10px rgba(0, 0, 0, 0.5);
}

  .slide-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn {
    font-family: var(--font-main);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    padding: 0.875rem 1.75rem;
    border-radius: 3px;
    transition: all 0.25s ease;
  }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
    box-shadow: 0 2px 10px rgba(124, 58, 237, 0.3);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
  }


  .slide-title {
  opacity: 0;
  transform: translateY(20px);
  animation: fadeInUp 0.8s ease 0.2s forwards;
}

.slide-subtitle {
  opacity: 0;
  transform: translateY(20px);
  animation: fadeInUp 0.8s ease 0.35s forwards;
}

.slide-buttons {
  opacity: 0;
  transform: translateY(20px);
  animation: fadeInUp 0.8s ease 0.5s forwards;
}

@keyframes fadeInUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

  @media (min-width: 768px) {
    .hero {
      margin-top: 65px;
      height: calc(100vh - 65px);
      max-height: 75vh;
    }

    .slide-buttons {
      gap: 1.25rem;
    }

    .btn {
      padding: 1rem 2rem;
    }
  }
</style>