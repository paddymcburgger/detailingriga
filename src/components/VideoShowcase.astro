---
interface Props {
  youtubeId?: string;
  videoSrc?: string;
  posterSrc?: string;
  title: string;
  primaryBtn?: {
    label: string;
    href: string;
  };
  secondaryBtn?: {
    label: string;
    href: string;
  };
}

const { 
  youtubeId,
  videoSrc,
  posterSrc,
  title = 'Полировка стёкол',
  primaryBtn = { label: 'резервация', href: '#booking' },
  secondaryBtn = { label: 'об услуге', href: '#service' },
} = Astro.props;

const isYoutube = !!youtubeId;
const youtubeEmbedUrl = youtubeId 
  ? `https://www.youtube.com/embed/${youtubeId}?autoplay=1&mute=1&loop=1&playlist=${youtubeId}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1`
  : '';
---

<section class="video-section">
  <div class="video-container">
    {isYoutube ? (
      <iframe
        class="video-player video-iframe"
        src={youtubeEmbedUrl}
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    ) : (
      <>
        <video 
          class="video-player"
          src={videoSrc}
          poster={posterSrc}
          muted
          loop
          playsinline
          autoplay
        ></video>
        
        <button class="pause-btn" aria-label="Пауза">
          <svg class="icon-pause" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <rect x="6" y="4" width="4" height="16" rx="1" />
            <rect x="14" y="4" width="4" height="16" rx="1" />
          </svg>
          <svg class="icon-play" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" style="display: none;">
            <path d="M8 5.14v14.72a1 1 0 001.5.86l11-7.36a1 1 0 000-1.72l-11-7.36a1 1 0 00-1.5.86z" />
          </svg>
        </button>
      </>
    )}
    
    <div class="video-overlay"></div>
    
    <div class="video-content">
      <h2 class="video-title">{title}</h2>
      <div class="video-buttons">
        {primaryBtn && (
          <a href={primaryBtn.href} class="btn btn-primary">
            {primaryBtn.label}
          </a>
        )}
        {secondaryBtn && (
          <a href={secondaryBtn.href} class="btn btn-secondary">
            {secondaryBtn.label}
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .video-section {
    padding: 3rem 1.5rem;
    background: var(--color-bg);
  }

  .video-container {
    position: relative;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .video-player {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: #1a1a1a;
  }

  .video-iframe {
    border: none;
    pointer-events: none;
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.2) 50%,
      rgba(0, 0, 0, 0.6) 100%
    );
    pointer-events: none;
  }

  .pause-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(10px);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 20;
  }

  .pause-btn:hover {
    background: rgba(0, 0, 0, 0.7);
    transform: scale(1.05);
  }

  .video-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem;
    z-index: 10;
  }

  .video-title {
    font-family: var(--font-main);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 1.25rem;
    line-height: 1.2;
    text-shadow: 0 2px 15px rgba(0, 0, 0, 0.4);
  }

  .video-buttons {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }


  @media (min-width: 768px) {
    .video-section {
      padding: 4rem 2rem;
    }

    .video-content {
      padding: 2.5rem;
    }

    .pause-btn {
      top: 1.5rem;
      right: 1.5rem;
    }



  @media (min-width: 1024px) {
    .video-section {
      padding: 5rem 3rem;
    }

    .video-content {
      padding: 3rem;
    }

    .video-buttons {
      gap: 1rem;
    }
  }
</style>

<script>
  const video = document.querySelector('.video-player') as HTMLVideoElement;
  const pauseBtn = document.querySelector('.pause-btn');
  const iconPause = document.querySelector('.icon-pause') as HTMLElement;
  const iconPlay = document.querySelector('.icon-play') as HTMLElement;

  pauseBtn?.addEventListener('click', () => {
    if (video.paused) {
      video.play();
      iconPause.style.display = 'block';
      iconPlay.style.display = 'none';
    } else {
      video.pause();
      iconPause.style.display = 'none';
      iconPlay.style.display = 'block';
    }
  });
</script>
