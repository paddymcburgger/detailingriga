---
import Layout from '../../layouts/Layout.astro';
import ServiceCards from '../../components/ServiceCards.astro';
import Footer from '../../components/Footer.astro';
import { getTranslations } from '../../i18n/translations';


const lang = 'ru';
const t = getTranslations(lang);

const services = [
  {
    image: '/images/services/boat-glass.jpg',
    title: t.services.boatGlass,
    bookingHref: '/contact',
    detailsHref: '/boats/glass-restoration',
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/boat-ppf.jpg',
    title: t.services.boatPpf,
    bookingHref: '/contact',
    detailsHref: '/boats/ppf',
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/boat-vinyl.jpg',
    title: t.services.boatVinyl,
    bookingHref: '/contact',
    detailsHref: '/boats/vinyl',
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/boat-graphics.jpg',
    title: t.services.boatGraphics,
    bookingHref: '/contact',
    detailsHref: '/boats/graphics',
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/boat-upholstery.jpg',
    title: t.services.boatUpholstery,
    bookingHref: '/contact',
    detailsHref: '/boats/upholstery',
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
];
---

<Layout 
  title="Детейлинг для лодок и катеров | Рига"
  description="Оклейка, полировка, перетяжка салона для яхт и катеров в Риге."
  lang={lang}
>
  <section class="hero">
    <h1>Лодки и катера</h1>
    <p>Защита, уход и обновление</p>
  </section>
  
  <ServiceCards services={services} />
  <Footer 
  ctaSmall="Искали детейлинг яхт в Риге?"
  ctaLarge="ДАВАЙТЕ ОБСУДИМ"
/>
</Layout>

<style>
  .hero {
    margin-top: 57px;
    padding: 5rem 2rem;
    background: var(--color-bg-dark);
    text-align: center;
  }

  .hero h1 {
    font-family: var(--font-main);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 1rem;
  }

  .hero p {
    font-family: var(--font-main);
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  @media (min-width: 768px) {
    .hero {
      margin-top: 65px;
      padding: 6rem 2rem;
    }
  }
</style>
