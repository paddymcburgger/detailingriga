---
import Layout from '../../layouts/Layout.astro';
import ServiceCards from '../../components/ServiceCards.astro';
import Footer from '../../components/Footer.astro';

import SectionHero from '../../components/SectionHero.astro';
import boatsHeroImg from '../../assets/images/boats/boats-hero.jpg';

import { getTranslations } from '../../i18n/translations';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const lang = 'ru';
const t = getTranslations(lang);

const services = [
  {
    image: '/images/services/boat-glass.jpg',
    title: t.services.boatGlass,
    bookingHref: '#contact-form',
    detailsHref: `${base}/boats/glass-restoration`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/boat-ppf.jpg',
    title: t.services.boatPpf,
    bookingHref: '#contact-form',
    detailsHref: `${base}/boats/ppf`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/boat-vinyl.jpg',
    title: t.services.boatVinyl,
    bookingHref: '#contact-form',
    detailsHref: `${base}/boats/vinyl`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/boat-graphics.jpg',
    title: t.services.boatGraphics,
    bookingHref: '#contact-form',
    detailsHref: `${base}/boats/graphics`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/boat-upholstery.jpg',
    title: t.services.boatUpholstery,
    bookingHref: '#contact-form',
    detailsHref: `${base}/boats/upholstery`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
];
---

<Layout 
  title="Детейлинг для лодок и катеров | Рига"
  description="Оклейка, полировка, перетяжка салона для яхт и катеров в Риге."
  lang={lang}
>
  <SectionHero 
  title="Лодки и катера"
  subtitle="Защита, уход и обновление"
  backgroundImage={boatsHeroImg}
  primaryBtn={{ label: 'резервация', href: '#contact-form' }}
  secondaryBtn={{ label: 'об услугах', href: '#services' }}
  />
  <ServiceCards services={services} />
  <Footer 
  ctaSmall="Искали детейлинг яхт в Риге?"
  ctaLarge="ДАВАЙТЕ ОБСУДИМ"
  />
  </Layout>

<style>
  .hero {
    margin-top: 57px;
    padding: 5rem 2rem;
    background: var(--color-bg-dark);
    text-align: center;
  }

  .hero h1 {
    font-family: var(--font-main);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 1rem;
  }

  .hero p {
    font-family: var(--font-main);
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  @media (min-width: 768px) {
    .hero {
      margin-top: 65px;
      padding: 6rem 2rem;
    }
  }
</style>
