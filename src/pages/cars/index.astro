---
import Layout from '../../layouts/Layout.astro';
import HeroCarousel from '../../components/HeroCarousel.astro';
import boatsHeroImg from '../../assets/images/boats/boats-hero.jpg';
import waterStoneImg from '../../assets/images/services/water-stone.jpg';
import headlightsImg from '../../assets/images/services/headlights.jpg';

import ServiceCards from '../../components/ServiceCards.astro';
import Footer from '../../components/Footer.astro';
import ContactFormModal from '../../components/ContactFormModal.astro';
import { getTranslations } from '../../i18n/translations';


const lang = 'ru';
const t = getTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const services = [
  {
    image: '/images/services/glass-restoration.jpg',
    title: 'Восстановление стёкол',
    bookingHref: '#contact-form',
    detailsHref: `${base}/cars/glass-restoration`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/ppf.jpg',
    title: 'Защитная плёнка PPF',
    bookingHref: '#contact-form',
    detailsHref: `${base}/cars/ppf`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/vinyl.jpg',
    title: 'Виниловая оклейка',
    bookingHref: '#contact-form',
    detailsHref: `${base}/cars/vinyl`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/graphics.jpg',
    title: 'Графика и полосы',
    bookingHref: '#contact-form',
    detailsHref: `${base}/cars/graphics`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/tint.jpg',
    title: 'Тонировка стёкол',
    bookingHref: '#contact-form',
    detailsHref: `${base}/cars/tint`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/paint-correction.jpg',
    title: 'Полировка кузова',
    bookingHref: '#contact-form',
    detailsHref: `${base}/cars/paint-correction`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
];
---

<Layout 
  title="Услуги для автомобилей | Detailing Riga"
  description="Защита и уход за автомобилем в Риге. PPF, винил, тонировка, полировка, восстановление стёкол."
  lang={lang}
>
<HeroCarousel slides={[
  {
    type: 'image',
    src: waterStoneImg.src,
    title: 'Удаление водного камня',
    subtitle: 'Восстановление прозрачности стёкол',
    primaryBtn: { label: 'резервация', href: '#contact-form' },
    secondaryBtn: { label: 'об услуге', href: '/cars/glass-restoration' },
  },
  {
    type: 'image',
    src: headlightsImg.src,
    title: 'Полировка фар',
    subtitle: 'Возвращаем яркость света',
    primaryBtn: { label: 'резервация', href: '#contact-form' },
    secondaryBtn: { label: 'об услуге', href: '/cars/headlights' },
  },
]} />
  
  <ServiceCards services={services} />
  <Footer 
  ctaSmall="Искали детейлинг авто в Риге?"
  ctaLarge="ДАВАЙТЕ ОБСУДИМ"
/>
<ContactFormModal />
</Layout>

<style>
  .hero {
    margin-top: 57px;
    padding: 5rem 2rem;
    background: var(--color-bg-dark);
    text-align: center;
  }

  .hero h1 {
    font-family: var(--font-main);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 1rem;
  }

  .hero p {
    font-family: var(--font-main);
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  @media (min-width: 768px) {
    .hero {
      margin-top: 65px;
      padding: 6rem 2rem;
    }
  }
</style>