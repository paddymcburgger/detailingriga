---
import Layout from '../../layouts/Layout.astro';
import HeroCarousel from '../../components/HeroCarousel.astro';
import ServiceCards from '../../components/ServiceCards.astro';
import VideoShowcase from '../../components/VideoShowcase.astro';
import SocialProof from '../../components/SocialProof.astro';
import Footer from '../../components/Footer.astro';
import ContactFormModal from '../../components/ContactFormModal.astro';
import { getTranslations } from '../../i18n/translations';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const lang = 'en';
const t = getTranslations(lang);

// Hero slides
const heroSlides = [
  {
    type: 'image' as const,
    src: '/images/hero-glass-polishing.jpg',
    title: t.services.glassPolishing,
    subtitle: '-30% with rain repellent',
    primaryBtn: { label: t.hero.booking, href: '#contact-form' },
    secondaryBtn: { label: t.hero.learnMore, href: `${base}/en/services/glass-polishing` },
  },
  {
    type: 'image' as const,
    src: '/images/hero-ceramic.jpg',
    title: t.services.ceramic,
    subtitle: 'Protection up to 5 years',
    primaryBtn: { label: t.hero.booking, href: '#contact-form' },
    secondaryBtn: { label: t.hero.learnMore, href: `${base}/en/services/ceramic-coating` },
  },
];

// Service cards
const services = [
  {
    image: '/images/services/chip-removal.jpg',
    title: t.services.chipRemoval,
    bookingHref: '#contact-form',
    detailsHref: `${base}/en/services/chip-removal`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/ppf.jpg',
    title: t.services.ppf,
    bookingHref: '#contact-form',
    detailsHref: `${base}/en/services/ppf`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/water-stone.jpg',
    title: t.services.waterStone,
    bookingHref: '#contact-form',
    detailsHref: `${base}/en/services/water-spot-removal`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/headlights.jpg',
    title: t.services.headlights,
    bookingHref: '#contact-form',
    detailsHref: `${base}/en/services/headlight-restoration`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
];
---

<Layout 
  title={t.seo.homeTitle}
  description={t.seo.siteDescription}
  lang={lang}
>
  <HeroCarousel slides={heroSlides} />
  <ServiceCards services={services} />
  <VideoShowcase 
    youtubeId="dQw4w9WgXcQ"
    title={t.services.glassPolishing}
    primaryBtn={{ label: t.common.booking, href: '#contact-form' }}
    secondaryBtn={{ label: t.common.details, href: `${base}/en/services/glass-polishing` }}
  />
  <SocialProof 
    text="see examples of restoration and protection work, over 10 types of car and yacht care services"
    linkText="view our projects"
    linkHref={`${base}/en/projects`}
  />
  <Footer 
    ctaSmall="Need Detailing?"
    ctaLarge="LET'S TALK"
    ctaHref="#contact-form"
  />
  <ContactFormModal />
</Layout>