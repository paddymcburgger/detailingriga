---
import Layout from '../../layouts/Layout.astro';
import { getTranslations } from '../../i18n/translations';

const lang = 'ru';
const t = getTranslations(lang);

// Service data - change for each service
const service = {
  title: 'Удаление водного камня',
  subtitle: 'Безопасное вождение в дождь и темноте',
  heroImage: '/images/services/water-stone-hero.jpg',
  description: {
    heading: 'Чистые стёкла — безопасная дорога',
    text: 'Водный камень образуется от жёсткой воды и создаёт блики при встречном свете. Это ухудшает видимость ночью и в дождь. Мы удаляем минеральные отложения без повреждения стекла, восстанавливая полную прозрачность.',
    image: '/images/services/water-stone-detail.jpg',
  },
  process: {
    heading: 'Процесс работы',
    subtitle: 'Профессиональное удаление в 4 этапа',
    steps: [
      {
        title: 'Диагностика',
        text: 'Оцениваем степень загрязнения и состояние стекла',
        image: '/images/process/step-1.jpg',
      },
      {
        title: 'Подготовка',
        text: 'Очищаем поверхность от грязи и жира',
        image: '/images/process/step-2.jpg',
      },
      {
        title: 'Обработка',
        text: 'Удаляем минеральные отложения специальным составом',
        image: '/images/process/step-3.jpg',
      },
      {
        title: 'Защита',
        text: 'Наносим гидрофобное покрытие для защиты',
        image: '/images/process/step-4.jpg',
      },
    ],
  },
  cta: {
    heading: 'Верните прозрачность стёклам',
    subheading: 'Запишитесь на диагностику или получите консультацию',
    primaryBtn: { label: 'Записаться', href: '#booking' },
    secondaryBtn: { label: 'Связаться', href: '/contact' },
  },
};

const seoTitle = `${service.title} в Риге | Детейлинг`;
const seoDescription = `${service.description.text.slice(0, 155)}...`;
---

<Layout title={seoTitle} description={seoDescription} lang={lang}>
  
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-image" style={`background-image: url(${service.heroImage})`}>
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <h1 class="hero-title">{service.title}</h1>
      <p class="hero-subtitle">{service.subtitle}</p>
    </div>
  </section>

  <!-- Description Section -->
  <section class="description">
    <div class="description-container">
      <div class="description-text">
        <h2 class="description-heading">{service.description.heading}</h2>
        <p class="description-body">{service.description.text}</p>
        <div class="description-cta">
          <a href="#booking" class="btn btn-primary">{t.common.booking}</a>
        </div>
      </div>
      <div class="description-image">
        <img src={service.description.image} alt={service.title} loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="process">
    <div class="process-header">
      <h2 class="process-heading">{service.process.heading}</h2>
      <p class="process-subtitle">{service.process.subtitle}</p>
    </div>
    
    <div class="process-carousel">
      <div class="process-track">
        {service.process.steps.map((step, index) => (
          <div class="process-card">
            <div class="process-card-image">
              <img src={step.image} alt={step.title} loading="lazy" />
            </div>
            <div class="process-card-content">
              <span class="process-card-number">{(index + 1).toString().padStart(2, '0')}</span>
              <h3 class="process-card-title">{step.title}</h3>
              <p class="process-card-text">{step.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
    
    <div class="process-dots">
      {service.process.steps.map((_, index) => (
        <button 
          class={`dot ${index === 0 ? 'active' : ''}`}
          data-slide={index}
          aria-label={`Шаг ${index + 1}`}
        />
      ))}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="cta-container">
      <h2 class="cta-heading">{service.cta.heading}</h2>
      <p class="cta-subheading">{service.cta.subheading}</p>
      <div class="cta-buttons">
        <a href={service.cta.primaryBtn.href} class="btn btn-primary">{service.cta.primaryBtn.label}</a>
        <a href={service.cta.secondaryBtn.href} class="btn btn-secondary">{service.cta.secondaryBtn.label}</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    height: 70vh;
    min-height: 500px;
    max-height: 800px;
    margin-top: 57px;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-color: #1a1a1a;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.2) 0%,
      rgba(0, 0, 0, 0.5) 100%
    );
  }

  .hero-content {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 2rem;
    z-index: 10;
  }

  .hero-title {
    font-family: var(--font-main);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-family: var(--font-main);
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  /* Description */
  .description {
    padding: 5rem 1.5rem;
    background: var(--color-white);
  }

  .description-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  .description-heading {
    font-family: var(--font-main);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 1.5rem;
    letter-spacing: -0.02em;
  }

  .description-body {
    font-family: var(--font-main);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text-light);
    margin: 0 0 2rem;
  }

  .description-cta {
    margin-top: 1.5rem;
  }

  .description-image {
    border-radius: 12px;
    overflow: hidden;
  }

  .description-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Process */
  .process {
    padding: 5rem 0;
    background: var(--color-bg);
  }

  .process-header {
    text-align: center;
    padding: 0 1.5rem;
    margin-bottom: 3rem;
  }

  .process-heading {
    font-family: var(--font-main);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.75rem;
  }

  .process-subtitle {
    font-family: var(--font-main);
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .process-carousel {
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .process-carousel::-webkit-scrollbar {
    display: none;
  }

  .process-track {
    display: flex;
    gap: 1.5rem;
    padding: 0 1.5rem;
    width: max-content;
  }

  .process-card {
    flex-shrink: 0;
    width: 300px;
    background: var(--color-white);
    border-radius: 12px;
    overflow: hidden;
    scroll-snap-align: center;
    transition: transform 0.3s ease;
  }

  .process-card:hover {
    transform: translateY(-4px);
  }

  .process-card-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #e5e5e5;
  }

  .process-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .process-card-content {
    padding: 1.5rem;
  }

  .process-card-number {
    font-family: var(--font-main);
    font-size: 0.75rem;
    font-weight: 600;
    color: #7c3aed;
    letter-spacing: 0.05em;
  }

  .process-card-title {
    font-family: var(--font-main);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0.5rem 0;
  }

  .process-card-text {
    font-family: var(--font-main);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  .process-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2rem;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.2);
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .dot:hover {
    background: rgba(0, 0, 0, 0.4);
  }

  .dot.active {
    background: var(--color-accent);
    transform: scale(1.25);
  }

  /* CTA Section */
  .cta-section {
    padding: 5rem 1.5rem;
    background: var(--color-bg-dark);
  }

  .cta-container {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-heading {
    font-family: var(--font-main);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    color: #fff;
    margin: 0 0 1rem;
  }

  .cta-subheading {
    font-family: var(--font-main);
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 2rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn {
    font-family: var(--font-main);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    padding: 0.875rem 1.75rem;
    border-radius: 3px;
    transition: all 0.25s ease;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
    box-shadow: 0 2px 10px rgba(124, 58, 237, 0.3);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(124, 58, 237, 0.4);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
  }

  /* Responsive */
  @media (min-width: 768px) {
    .hero {
      margin-top: 65px;
    }

    .description {
      padding: 6rem 2rem;
    }

    .description-container {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }

    .process {
      padding: 6rem 0;
    }

    .process-track {
      padding: 0 2rem;
      gap: 2rem;
    }

    .process-card {
      width: 350px;
    }

    .cta-section {
      padding: 6rem 2rem;
    }
  }

  @media (min-width: 1024px) {
    .description {
      padding: 8rem 3rem;
    }

    .process-track {
      padding: 0 3rem;
    }

    .process-card {
      width: 400px;
    }

    .process-dots {
      display: none;
    }
  }
</style>

<script>
  // Process carousel dots
  const carousel = document.querySelector('.process-carousel');
  const cards = document.querySelectorAll('.process-card');
  const dots = document.querySelectorAll('.process-dots .dot');
  let currentIndex = 0;

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      const card = cards[index] as HTMLElement;
      if (card && carousel) {
        const scrollLeft = card.offsetLeft - 24;
        carousel.scrollTo({ left: scrollLeft, behavior: 'smooth' });
      }
    });
  });

  carousel?.addEventListener('scroll', () => {
    if (!carousel) return;
    const scrollLeft = carousel.scrollLeft;
    
    let closestIndex = 0;
    let closestDistance = Infinity;

    cards.forEach((card, index) => {
      const cardLeft = (card as HTMLElement).offsetLeft - 24;
      const distance = Math.abs(scrollLeft - cardLeft);
      if (distance < closestDistance) {
        closestDistance = distance;
        closestIndex = index;
      }
    });

    if (closestIndex !== currentIndex) {
      currentIndex = closestIndex;
      dots.forEach((dot, index) => {
        dot.classList.toggle('active', index === currentIndex);
      });
    }
  });
</script>
