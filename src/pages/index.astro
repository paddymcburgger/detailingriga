---
import Layout from '../layouts/Layout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import ServiceCards from '../components/ServiceCards.astro';
import VideoShowcase from '../components/VideoShowcase.astro';
import ContactFormModal from '../components/ContactFormModal.astro';
import SocialProof from '../components/SocialProof.astro';
import Footer from '../components/Footer.astro';

import { getTranslations } from '../i18n/translations';

import heroGlassImg from '../assets/images/hero-glass-polishing.jpg';
import heroCeramicImg from '../assets/images/hero-ceramic.jpg';
import chipRemovalImg from '../assets/images/services/chip-removal.jpg';
import ppfImg from '../assets/images/services/ppf.jpg';
import waterStoneImg from '../assets/images/services/water-stone.jpg';
import headlightsImg from '../assets/images/services/headlights.jpg';

const lang = 'ru';
const t = getTranslations(lang);
const base = import.meta.env.BASE_URL;

const heroSlides = [
  {
    type: 'image' as const,
    src: heroGlassImg.src,
    title: t.services.glassPolishing,
    subtitle: '-30% вместе с антидождь',
    primaryBtn: { label: t.hero.booking, href: '#contact-form' },
    secondaryBtn: { label: t.hero.learnMore, href: `${base}/cars/glass-restoration` },
  },
  {
    type: 'image' as const,
    src: heroCeramicImg.src,
    title: t.services.ceramic,
    subtitle: 'Защита до 5 лет',
    primaryBtn: { label: t.hero.booking, href: '#contact-form' },
    secondaryBtn: { label: t.hero.learnMore, href: `${base}/cars/ppf` },
  },
];

const services = [
  {
    image: chipRemovalImg.src,
    title: t.services.chipRemoval,
    bookingHref: '#contact-form',
    detailsHref: `${base}/cars/chip-removal`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: ppfImg.src,
    title: t.services.ppf,
    bookingHref: '#contact-form',
    detailsHref: `${base}/cars/ppf`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: waterStoneImg.src,
    title: t.services.waterStone,
    bookingHref: '#contact-form',
    detailsHref: `${base}/cars/water-stone`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: headlightsImg.src,
    title: t.services.headlights,
    bookingHref: '#contact-form',
    detailsHref: `${base}/cars/headlights`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
];

const services2 = [
  {
    image: '/images/services/boat-upholstery.jpg',
    title: t.services.boatUpholstery,
    bookingHref: '#contact-form',
    detailsHref: `${base}/boats/upholstery`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/boat-vinyl.jpg',
    title: t.services.boatVinyl,
    bookingHref: '#contact-form',
    detailsHref: `${base}/boats/vinyl`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/signage.jpg',
    title: t.services.signage,
    bookingHref: '#contact-form',
    detailsHref: `${base}/business/signage`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
  {
    image: '/images/services/windows.jpg',
    title: t.services.windowGraphics,
    bookingHref: '#contact-form',
    detailsHref: `${base}/business/window-graphics`,
    bookingLabel: t.common.booking,
    detailsLabel: t.common.details,
  },
];
---

<Layout 
  title={t.seo.homeTitle}
  description={t.seo.siteDescription}
  lang={lang}
>
  <HeroCarousel slides={heroSlides} />
  <ServiceCards services={services} />
  <VideoShowcase 
    youtubeId="dQw4w9WgXcQ"
    title={t.services.glassPolishing}
    primaryBtn={{ label: t.common.booking, href: '#contact-form' }}
    secondaryBtn={{ label: t.common.details, href: `${base}/cars/glass-polishing` }}
  />
  <ServiceCards services={services2} />
  <SocialProof />
  <Footer />
  
  <ContactFormModal />
</Layout>