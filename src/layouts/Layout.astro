---
import Header from '../components/Header.astro';
import { getTranslations, defaultLang } from '../i18n/translations';

interface Props {
  title: string;
  description: string;
  lang?: string;
  logo?: string;
}

const { 
  title, 
  description, 
  lang = defaultLang,
  logo = "лого"
} = Astro.props;

const t = getTranslations(lang as 'ru' | 'en');
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const alternateRu = lang === 'ru' ? canonicalURL : new URL(Astro.url.pathname.replace(/^\/en/, ''), Astro.site);
const alternateEn = lang === 'en' ? canonicalURL : new URL(`/en${Astro.url.pathname}`, Astro.site);
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  
  <!-- Language alternates for SEO -->
  <link rel="alternate" hreflang="ru" href={alternateRu} />
  <link rel="alternate" hreflang="en" href={alternateEn} />
  <link rel="alternate" hreflang="x-default" href={alternateRu} />
  
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content={lang === 'ru' ? 'ru_RU' : 'en_US'} />
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  
  <!-- Favicon (add your own later) -->
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
</head>
<body>
  <Header logo={logo} currentLang={lang} />
  
  <main>
    <slot />
  </main>
  
  <!-- Footer will go here -->
</body>
</html>

<style is:global>
  :root {
  --font-main: 'Roboto', system-ui, sans-serif;
  --color-text: #111;
  --color-text-light: #444;
  --color-text-muted: #666;
  --color-accent: #7c3aed;
  --color-accent-hover: #6d28d9;
  --color-bg: #f5f5f5;
  --color-bg-dark: #111;
  --color-white: #fff;
}
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  * {
    margin: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background: var(--color-bg);
    color: var(--color-text);
  }

  .btn {
  font-family: var(--font-main);
  font-size: 0.9375rem;
  font-weight: 500;
  text-decoration: none;
  padding: 0.875rem 1.75rem;
  border-radius: 3px;
  transition: all 0.25s ease;
  cursor: pointer;
  border: none;
}

.btn-primary {
  background: var(--color-accent);
  color: var(--color-white);
  box-shadow: 0 2px 10px rgba(124, 58, 237, 0.3);
}

.btn-primary:hover {
  background: var(--color-accent-hover);
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(124, 58, 237, 0.4);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: var(--color-white);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.btn-secondary:hover {
  background: rgba(255, 255, 255, 0.15);
  transform: translateY(-2px);
}

  img,
  video {
    display: block;
    max-width: 100%;
  }

  button {
    font: inherit;
  }

  a {
    color: inherit;
  }

  
</style>
